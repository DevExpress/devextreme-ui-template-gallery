{
  "name": "devextreme-ui-template-gallery",
  "version": "1.0.0",
  "packageManager": "pnpm@11.5.1",
  "private": true,
  "scripts": {
    "build": "pnpm -r run build",
    "set-theme": "node utils/set-theme.js",
    "copy-build": "node utils/copy-build.js",
    "copy-shell": "node utils/copy-shell.js",
    "make-embedded-mode": "node utils/make-embedded-mode.js",
    "lint-html": "prettier --write . && prettier --check .",
    "lint-js": "eslint .",
    "lint-fix": "prettier --write . && pnpm run lint-angular-fix && pnpm run lint-react-fix && pnpm run lint-shell-fix && pnpm run lint-utils-fix && stylelint **/*.{css,scss} --fix",
    "lint-css": "stylelint **/*.{css,scss}",
    "lint-css-fix": "stylelint --fix **/*.{css,scss}",
    "lint-angular": "eslint packages/angular",
    "lint-react": "pnpm --filter react-app run lint",
    "lint-vue": "pnpm --filter vue-ui-template-gallery run lint",
    "lint-utils": "eslint utils/",
    "lint-bundles": "pnpm run lint-angular && pnpm run lint-react && pnpm run lint-vue",
    "lint-angular-fix": "eslint --fix packages/angular",
    "lint-react-fix": "pnpm --filter react-app run lint -- --fix",
    "lint-shell-fix": "eslint --fix packages/shell",
    "lint-utils-fix": "eslint --fix utils",
    "lint-utils --fix": "eslint --fix utils"
  },
  "devDependencies": {
    "@babel/runtime": "^7.29.7",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "@typescript-eslint/utils": "^8.61.1",
    "@types/node": "^24.13.2",
    "devextreme-cli": "latest",
    "eslint": "^8.57.1",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-airbnb-typescript": "^17.1.0",
    "eslint-config-react-app": "^7.0.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jest": "^27.9.0",
    "eslint-plugin-n": "^14.0.0",
    "eslint-plugin-no-only-tests": "^3.4.0",
    "eslint-plugin-promise": "^6.6.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-perf": "^3.3.3",
    "eslint-plugin-spellcheck": "^0.0.20",
    "fs-extra": "^10.1.0",
    "globals": "^16.5.0",
    "prettier": "2.4.1",
    "stylelint": "^15.11.0",
    "stylelint-config-standard": "^33.0.0",
    "stylelint-config-standard-scss": "^11.1.0",
    "stylelint-scss": "^5.3.2",
    "typescript": "~5.8.3",
    "vue": "^3.5.38",
    "vue-eslint-parser": "^9.4.3"
  },
  "dependencies": {
    "devextreme": "~26.1.3",
    "devextreme-dist": "~26.1.3",
    "devexpress-gantt": "^4.1.69",
    "devextreme-schematics": "^1.15.0",
    "devextreme-themebuilder": "~26.1.3",
    "eslint-config-devextreme": "1.1.6",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8"
  },
  "pre-commit": [
    "lint-bundles"
  ],
  "engines": {
    "node": "^24.18.0"
  }
}
